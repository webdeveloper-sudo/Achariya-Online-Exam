datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String   @default("Admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admins")
}

model Teacher {
  id             String    @id @default(uuid())
  userId         String    @unique // Employee ID, e.g. TCH001
  userName       String
  joiningDate    DateTime
  branch         String
  designation    String
  subjects       String[]  @default([])
  qualifications String    @default("")
  gradesInCharge String[]  @default([])
  experience     String    @default("")
  mobileNo       String    @default("")
  email          String    @default("")
  status         String    @default("Active") // Active, Inactive, On Leave
  password       String?   // Hashed password, null until activated
  activated      Boolean   @default(false)
  activatedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  assessments    Assessment[]

  @@map("teachers")
}

model Otp {
  id          String   @id @default(uuid())
  identifier  String   // Email or User ID
  otp         String
  contactType String   @default("email")
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  @@map("otps")
}

model Assessment {
  id                  String        @id @default(uuid())
  title               String
  duration            Int           @default(30) // in minutes
  subject             String
  lesson              String
  isPublic            Boolean       @default(false)
  questions           Json          // Array of question objects
  createdById         String
  createdByEmail      String
  createdByTeacherName String
  createdBy           Teacher       @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  liveSessions        LiveSession[]

  @@map("assessments")
}

enum LiveSessionStatus {
  WAITING
  ACTIVE
  COMPLETED
}

model LiveSession {
  id           String                   @id @default(uuid())
  token        String                   @unique
  assessmentId String
  teacherId    String
  status       LiveSessionStatus        @default(WAITING)
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime                 @default(now())
  assessment   Assessment               @relation(fields: [assessmentId], references: [id])
  participants LiveSessionParticipant[]

  @@map("live_sessions")
}

model LiveSessionParticipant {
  id               String      @id @default(uuid())
  sessionId        String
  name             String
  grade            String
  section          String
  studentId        String
  joinedAt         DateTime    @default(now())
  completedAt      DateTime?
  timeTakenSeconds Int?
  score            Int?
  totalQuestions   Int?
  answers          Json?
  tabSwitches      Int         @default(0)
  session          LiveSession @relation(fields: [sessionId], references: [id])

  @@map("live_session_participants")
}

model Recruiter {
  id           String                  @id @default(uuid())
  email        String                  @unique
  passwordHash String
  name         String
  role         String                  @default("Recruiter")
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  assessments  RecruitmentAssessment[]

  @@map("recruiters")
}

model RecruitmentAssessment {
  id                  String                   @id @default(uuid())
  title               String
  isPublic            Boolean                  @default(false)
  teaching            String                   // teaching or non teaching
  department          String
  duration            Int                      @default(30) // in minutes
  date                String                   // Date of assessment, e.g. "2026-05-22"
  day                 String                   // Day of week, e.g. "Friday"
  generatedBy         String                   // Recruiter name
  position            String                   // Assessment to hire which position
  recruitmentFor      String                   // School name(s)
  questions           Json                     // Array of question objects
  createdById         String
  createdBy           Recruiter                @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  liveSessions        RecruitmentLiveSession[]

  @@map("recruitment_assessments")
}

model RecruitmentLiveSession {
  id           String                               @id @default(uuid())
  token        String                               @unique
  assessmentId String
  recruiterId  String
  status       LiveSessionStatus                    @default(WAITING)
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime                             @default(now())
  assessment   RecruitmentAssessment                @relation(fields: [assessmentId], references: [id])
  participants RecruitmentLiveSessionParticipant[]

  @@map("recruitment_live_sessions")
}

model RecruitmentLiveSessionParticipant {
  id               String                 @id @default(uuid())
  sessionId        String
  name             String
  email            String
  phone            String
  experience       String
  qualification    String
  joinedAt         DateTime               @default(now())
  completedAt      DateTime?
  timeTakenSeconds Int?
  score            Int?
  totalQuestions   Int?
  answers          Json?
  tabSwitches      Int                    @default(0)
  terminated       Boolean                @default(false)
  session          RecruitmentLiveSession @relation(fields: [sessionId], references: [id])

  @@map("recruitment_live_session_participants")
}

model Director {
  id           String               @id @default(uuid())
  email        String               @unique
  passwordHash String
  name         String
  role         String               @default("Director")
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  assessments  DirectorAssessment[]

  @@map("directors")
}

model DirectorAssessment {
  id                  String                @id @default(uuid())
  title               String
  isPublic            Boolean               @default(false)
  teaching            String                // teaching or non teaching
  department          String
  duration            Int                   @default(30) // in minutes
  date                String                // Date of assessment
  day                 String                // Day of week
  generatedBy         String                // Director name
  position            String                // Assessment for teachers (target role/subject)
  recruitmentFor      String                // School name(s)
  questions           Json                  // Array of question objects
  createdById         String
  createdBy           Director              @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  liveSessions        DirectorLiveSession[]

  @@map("director_assessments")
}

model DirectorLiveSession {
  id           String                           @id @default(uuid())
  token        String                           @unique
  assessmentId String
  directorId   String
  status       LiveSessionStatus                @default(WAITING)
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime                         @default(now())
  assessment   DirectorAssessment               @relation(fields: [assessmentId], references: [id])
  participants DirectorLiveSessionParticipant[]

  @@map("director_live_sessions")
}

model DirectorLiveSessionParticipant {
  id               String              @id @default(uuid())
  sessionId        String
  userId           String              // Employee ID of the teacher
  name             String
  email            String
  phone            String
  qualification    String
  branch           String
  designation      String
  joinedAt         DateTime            @default(now())
  completedAt      DateTime?
  timeTakenSeconds Int?
  score            Int?
  totalQuestions   Int?
  answers          Json?
  tabSwitches      Int                 @default(0)
  terminated       Boolean             @default(false)
  session          DirectorLiveSession @relation(fields: [sessionId], references: [id])

  @@map("director_live_session_participants")
}


